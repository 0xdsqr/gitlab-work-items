{
  "name": "github-work-items",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --cwd apps/tui build",
    "dev": "bun run --cwd apps/tui dev",
    "start": "bun run --cwd apps/tui start",
    "mock": "GWI_MOCK=1 bun run --cwd apps/tui start",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --deny-warnings .",
    "test": "bun run --filter '*' --if-present test",
    "typecheck": "bun run --filter '*' --if-present typecheck"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/react": "19.2.17",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "bun@1.3.13"
}
