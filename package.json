{
  "name": "gitlab-work-items",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "audit": "bun audit --ignore=GHSA-4x5r-pxfx-6jf8",
    "build": "bun run --cwd apps/tui build",
    "dev": "bun run --cwd apps/tui dev",
    "start": "bun run --cwd apps/tui start",
    "mock": "GLWI_MOCK=1 bun run --cwd apps/tui start",
    "format": "oxfmt --config .oxfmtrc.json .",
    "format:check": "oxfmt --config .oxfmtrc.json --check .",
    "lint": "oxlint --config .oxlintrc.json --deny-warnings .",
    "test": "bun run --filter '*' --if-present test",
    "typecheck": "bun run --filter '*' --if-present typecheck"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "oxfmt": "0.60.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "packageManager": "bun@1.3.14"
}
