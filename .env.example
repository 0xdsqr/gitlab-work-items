# GitLab.com is the default. Set this for a self-managed instance.
GITLAB_HOST=https://gitlab.com

# Authentication is resolved in this order:
# GITLAB_TOKEN, GITLAB_ACCESS_TOKEN, then the active `glab` login.
# Write actions require the `api` scope. Viewing alone only requires `read_api`.
# GITLAB_TOKEN=glpat-...

# Full path of the group shown in the Organization scope.
# GWI_GROUP=my-org

# Use deterministic local fixtures, including an example epic.
# GWI_MOCK=1
